<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#F5F7FA">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Database Debug Inspector"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#1A237E"
        android:layout_marginBottom="16dp"/>

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp">
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <Button
                android:id="@+id/btnFetchAttendance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Attendance"
                android:layout_marginEnd="8dp"/>
            <Button
                android:id="@+id/btnFetchPayroll"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Payroll"
                android:layout_marginEnd="8dp"/>
            <Button
                android:id="@+id/btnFetchHolidays"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Holidays" />
        </LinearLayout>
    </HorizontalScrollView>

    <TextView
        android:id="@+id/tvSessionInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#E8EAF6"
        android:padding="8dp"
        android:fontFamily="monospace"
        android:textSize="12sp"
        android:layout_marginBottom="8dp"
        android:text="Session Info Loading..."/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#FFFFFF"
        android:padding="8dp">
        <TextView
            android:id="@+id/tvRawOutput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:textSize="12sp"
            android:text="Click a button to inspect data..."/>
    </ScrollView>

    <Button
        android:id="@+id/btnCloseDebug"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Close Inspector"
        android:backgroundTint="#D32F2F"
        android:textColor="#FFFFFF"
        android:layout_marginTop="8dp"/>

</LinearLayout>
