<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <ImageView
                android:id="@+id/ivLeaveIcon"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/holidays" />

            <TextView
                android:id="@+id/tvLeaveType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_toEndOf="@id/ivLeaveIcon"
                android:layout_centerVertical="true"
                android:text="Leave Type"
                android:textColor="#000000"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvUsedStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:background="@drawable/rounded_bg"
                android:backgroundTint="#FFCDD2"
                android:paddingHorizontal="12dp"
                android:paddingVertical="4dp"
                android:text="Used: 0"
                android:textColor="#D32F2F"
                android:textSize="12sp"
                android:textStyle="bold" />
        </RelativeLayout>

        <ProgressBar
            android:id="@+id/pbLeave"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="8dp"
            android:layout_marginTop="16dp"
            android:progress="0"
            android:progressTint="#F44336" />

        <TextView
            android:id="@+id/tvTotalStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="0 of 0 Used"
            android:textAlignment="viewEnd"
            android:textColor="#757575"
            android:textSize="11sp"
            android:textStyle="bold" />
    </LinearLayout>
</androidx.cardview.widget.CardView>